{
  "name": "superduck-webcloner",
  "version": "0.1.0",
  "private": true,
  "description": "Clone any website into a clean Next.js or TanStack Start codebase using AI coding agents with SuperDuck browser automation — any model, anywhere",
  "author": "superduck-ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/superduck-ai/superduck-webcloner.git"
  },
  "homepage": "https://github.com/superduck-ai/superduck-webcloner",
  "bugs": {
    "url": "https://github.com/superduck-ai/superduck-webcloner/issues"
  },
  "keywords": [
    "superduck",
    "claude-code",
    "website-clone",
    "reverse-engineering",
    "nextjs",
    "tanstack-start",
    "ai",
    "template",
    "tailwindcss",
    "shadcn-ui",
    "browser-automation"
  ],
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "templates/*"
  ],
  "scripts": {
    "dev:nextjs": "npm -w nextjs run dev",
    "dev:tanstack": "npm -w tanstack-start run dev",
    "build:nextjs": "npm -w nextjs run build",
    "build:tanstack": "npm -w tanstack-start run build",
    "lint:nextjs": "npm -w nextjs run lint",
    "lint:tanstack": "npm -w tanstack-start run lint",
    "typecheck:nextjs": "npm -w nextjs run typecheck",
    "typecheck:tanstack": "npm -w tanstack-start run typecheck",
    "check:nextjs": "npm -w nextjs run check",
    "check:tanstack": "npm -w tanstack-start run check",
    "check": "npm run check:nextjs && npm run check:tanstack"
  }
}
